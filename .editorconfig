root = true

[*.{ts,tsx,js,jsx,css,html,json,md,yml,yaml,svg,txt,ps1,bat,cmd}]
charset = utf-8
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,css,html,json,md,yml,yaml,svg,txt}]
end_of_line = lf

[*.{ps1,bat,cmd}]
end_of_line = crlf
