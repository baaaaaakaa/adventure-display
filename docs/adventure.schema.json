{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.adventure-display/schema/adventure.schema.json",
  "title": "Adventure",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "subtitle",
    "assetLibrary",
    "audioLibrary",
    "characters",
    "monsterLibrary",
    "scenes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string",
      "minLength": 1
    },
    "audioLibrary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/audioTrack"
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/playerCharacter"
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scene"
      }
    },
    "assetLibrary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assetRecord"
      }
    },
    "monsterLibrary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/monsterBlock"
      }
    }
  },
  "$defs": {
    "playerCharacter": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "stats",
        "skills",
        "attacks",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "avatarSrc": {
          "type": [
            "string",
            "null"
          ]
        },
        "stats": {
          "type": "array"
        },
        "skills": {
          "type": "array"
        },
        "attacks": {
          "type": "array"
        },
        "text": {
          "type": "object"
        }
      }
    },
    "audioTrack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "kind",
        "src"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "music",
            "ambience",
            "sfx"
          ]
        },
        "src": {
          "type": "string"
        },
        "assetId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "handout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "caption",
        "body"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "caption": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "imageSrc": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageAssetId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "monsterFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "body"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checkClue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ability",
        "difficulty",
        "outcome"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "ability": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "monsterBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "subtitle",
        "armorClass",
        "hitPoints",
        "speed",
        "strength",
        "dexterity",
        "constitution",
        "intelligence",
        "wisdom",
        "charisma",
        "savingThrows",
        "skills",
        "senses",
        "languages",
        "challenge",
        "traits",
        "actions",
        "bonusActions",
        "reactions",
        "legendaryActions",
        "notes",
        "source",
        "size",
        "creatureType",
        "alignment",
        "proficiencyBonus",
        "hitPointsFormula",
        "damageVulnerabilities",
        "damageResistances",
        "damageImmunities",
        "conditionImmunities"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string",
          "minLength": 1
        },
        "imageSrc": {
          "type": [
            "string",
            "null"
          ]
        },
        "armorClass": {
          "type": "string",
          "minLength": 1
        },
        "hitPoints": {
          "type": "string",
          "minLength": 1
        },
        "speed": {
          "type": "string",
          "minLength": 1
        },
        "strength": {
          "type": "number"
        },
        "dexterity": {
          "type": "number"
        },
        "constitution": {
          "type": "number"
        },
        "intelligence": {
          "type": "number"
        },
        "wisdom": {
          "type": "number"
        },
        "charisma": {
          "type": "number"
        },
        "savingThrows": {
          "type": "string"
        },
        "skills": {
          "type": "string"
        },
        "senses": {
          "type": "string"
        },
        "languages": {
          "type": "string"
        },
        "challenge": {
          "type": "string"
        },
        "traits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFeature"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFeature"
          }
        },
        "bonusActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFeature"
          }
        },
        "reactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFeature"
          }
        },
        "legendaryActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFeature"
          }
        },
        "notes": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "creatureType": {
          "type": "string"
        },
        "alignment": {
          "type": "string"
        },
        "proficiencyBonus": {
          "type": "string"
        },
        "imageAssetId": {
          "type": [
            "string",
            "null"
          ]
        },
        "hitPointsFormula": {
          "type": "string"
        },
        "damageVulnerabilities": {
          "type": "string"
        },
        "damageResistances": {
          "type": "string"
        },
        "damageImmunities": {
          "type": "string"
        },
        "conditionImmunities": {
          "type": "string"
        },
        "infoSections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFeature"
          }
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "placeholder"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "placeholder": {
          "type": "string",
          "minLength": 1
        },
        "imageSrc": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageAssetId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "location",
        "accent",
        "gmSummary",
        "gmNotes",
        "splash",
        "map",
        "zones",
        "handouts",
        "checksClues",
        "monsterIds",
        "monsterBlocks",
        "recommendedAudio",
        "objectives"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "accent": {
          "type": "string",
          "enum": [
            "amber",
            "crimson",
            "ember",
            "gold",
            "olive",
            "rose",
            "slate",
            "teal",
            "violet"
          ]
        },
        "gmSummary": {
          "type": "string",
          "minLength": 1
        },
        "gmNotes": {
          "type": "string",
          "minLength": 1
        },
        "map": {
          "$ref": "#/$defs/map"
        },
        "handouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/handout"
          }
        },
        "checksClues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkClue"
          }
        },
        "monsterBlocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterBlock"
          }
        },
        "recommendedAudio": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "splash": {
          "$ref": "#/$defs/splash"
        },
        "zones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mapZone"
          }
        },
        "monsterIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "assetRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "kind",
        "mimeType",
        "originalName",
        "dataUrl"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "image",
            "audio"
          ]
        },
        "mimeType": {
          "type": "string"
        },
        "originalName": {
          "type": "string"
        },
        "dataUrl": {
          "type": "string"
        }
      }
    },
    "splash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "subtitle",
        "body"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "imageAssetId": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageSrc": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "mapZone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "note",
        "focusNote",
        "x",
        "y",
        "width",
        "height",
        "visibleToPlayers",
        "autoRevealOnEnter"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        },
        "focusNote": {
          "type": "string"
        },
        "linkedHandoutId": {
          "type": [
            "string",
            "null"
          ]
        },
        "linkedCheckId": {
          "type": [
            "string",
            "null"
          ]
        },
        "linkedMonsterId": {
          "type": [
            "string",
            "null"
          ]
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "visibleToPlayers": {
          "type": "boolean"
        },
        "autoRevealOnEnter": {
          "type": "boolean"
        }
      }
    }
  }
}
